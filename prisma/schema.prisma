generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(128)
  email     String   @unique @db.VarChar(255)
  password  String?  @db.VarChar(255)
  plan      String   @default("free") @db.VarChar(32)
  avatar         String?  @db.VarChar(512)
  dodoCustomerId String?
  dodoSubId      String?
  emailVerified  Boolean  @default(false)
  verifyToken    String?  @db.VarChar(128)
  verifyTokenExp DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  servers           Server[]
  ariaConversations AriaConversation[]
  rateLimits        RateLimit[]
  agentTokens       AgentToken[]

  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ─── Rate Limiting ───────────────────────────────────────────
model RateLimit {
  id        String   @id @default(cuid())
  userId    String
  date      String   @db.VarChar(10)  // "2025-01-15"
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("rate_limits")
}

// ─── SSH Agent Tokens ────────────────────────────────────────
model AgentToken {
  id         String    @id @default(cuid())
  userId     String
  serverId   String
  token      String    @unique @db.VarChar(64)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("agent_tokens")
}

// ─── Servers ─────────────────────────────────────────────────
model Server {
  id          String   @id @default(cuid())
  userId      String
  name        String   @db.VarChar(128)
  host        String   @db.VarChar(255)
  port        Int      @default(22)
  username    String   @default("root") @db.VarChar(64)
  status      String   @default("unknown") @db.VarChar(32)
  os          String?  @db.VarChar(64)
  cpuUsage    Float?
  ramUsage    Float?
  diskUsage   Float?
  uptime      BigInt?
  lastCheckAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentTokens AgentToken[]

  @@index([userId])
  @@map("servers")
}

// ─── ARIA Conversations ──────────────────────────────────────
model AriaConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @db.VarChar(255)
  mode      String   @db.VarChar(32)
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AriaMessage[]

  @@index([userId])
  @@index([userId, mode])
  @@index([userId, createdAt])
  @@map("aria_conversations")
}

model AriaMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   @db.VarChar(16)
  content        String   @db.Text
  metadata       Json?
  tokens         Int?
  createdAt      DateTime @default(now())

  conversation AriaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("aria_messages")
}
